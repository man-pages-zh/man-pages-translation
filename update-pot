#
# NOTE: with the unified po4a(1), the POT templates and the PO catalogs are
# refreshed together in a single pass, so there is no longer a separate
# POT-only step -- this is now equivalent to ./update-po and is kept only for
# backwards compatibility.

set -e

exec "$(dirname "$0")/update-po"
