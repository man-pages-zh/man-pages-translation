#!/bin/sh
#
# update-release -- (re)generate the released, translated man pages under src/.
#
# Copyright (c) 2015-2026 Boyuan Yang <073plan@gmail.com>
# This script is released into the Public Domain.
#
# Builds src/*/man*/* from the upstream man pages and the existing PO catalogs
# using the unified po4a(1) with --no-update, so no POT/PO file is modified.
# As with the previous po4a-translate step, only translations at or above
# po4a's default threshold (80%) are written out; pages below it are skipped and
# any existing output for them is left untouched.

set -e

. "$(dirname "$0")/update-lib.sh"

printf '# UPDATE-RELEASE (po4a --no-update, %s jobs) #####\n' "$_PO4A_JOBS"
run_po4a "--no-update"
printf '# UPDATE-RELEASE ### END #########################\n'
