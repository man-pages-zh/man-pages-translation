#!/bin/sh
#
# update-po -- refresh templates/*.pot and po/*.po from the upstream man pages.
#
# Copyright (c) 2015-2026 Boyuan Yang <073plan@gmail.com>
# This script is released into the Public Domain.
#
# With the unified po4a(1) the POT template and the PO catalog are refreshed
# together in a single pass (the old separate po4a-updatepo / msgmerge / msginit
# steps are gone: po4a updates the POT from the raw man page, merges it into the
# existing PO, and creates the PO from the POT when it does not exist yet).
# Runs with --no-translations, so nothing under src/ is touched.

set -e

. "$(dirname "$0")/update-lib.sh"

printf '# UPDATE-PO (po4a --no-translations, %s jobs) ####\n' "$_PO4A_JOBS"
run_po4a "--no-translations"
printf '# UPDATE-PO ### END ##############################\n'
