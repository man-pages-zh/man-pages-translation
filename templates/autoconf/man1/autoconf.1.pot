#. type: Plain text
#: raw/autoconf/man1/autoconf.1:5
msgid "autoconf - Generate configuration scripts"
msgstr ""

#. type: SH
#: raw/autoconf/man1/autoconf.1:5
#, no-wrap
msgid "SYNOPSIS"
msgstr ""

#. type: Plain text
#: raw/autoconf/man1/autoconf.1:8
msgid "B<autoconf> [I<\\,OPTION\\/>]... [I<\\,TEMPLATE-FILE\\/>]"
msgstr ""

#. type: SH
#: raw/autoconf/man1/autoconf.1:8
#, no-wrap
msgid "DESCRIPTION"
msgstr ""

#. type: Plain text
#: raw/autoconf/man1/autoconf.1:13
msgid ""
"Generate a configuration script from a TEMPLATE-FILE if given, or "
"\\&'configure.ac' if present, or else 'configure.in'.  Output is sent to the "
"standard output if TEMPLATE-FILE is given, else into \\&'configure'."
msgstr ""

