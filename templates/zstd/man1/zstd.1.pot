#. type: Plain text
#: raw/zstd/man1/zstd.1:6
msgid ""
"B<zstd> - zstd, zstdmt, unzstd, zstdcat - Compress or decompress .zst files"
msgstr ""

#. type: SH
#: raw/zstd/man1/zstd.1:7
#, no-wrap
msgid "SYNOPSIS"
msgstr ""

#. type: Plain text
#: raw/zstd/man1/zstd.1:9
msgid "B<zstd> [I<OPTIONS>] [-|I<INPUT-FILE>] [-o I<OUTPUT-FILE>]"
msgstr ""

#. type: Plain text
#: raw/zstd/man1/zstd.1:12
msgid "B<zstdmt> is equivalent to B<zstd -T0>"
msgstr ""

#. type: Plain text
#: raw/zstd/man1/zstd.1:15
msgid "B<unzstd> is equivalent to B<zstd -d>"
msgstr ""

#. type: Plain text
#: raw/zstd/man1/zstd.1:18
msgid "B<zstdcat> is equivalent to B<zstd -dcf>"
msgstr ""

#. type: SH
#: raw/zstd/man1/zstd.1:19
#, no-wrap
msgid "DESCRIPTION"
msgstr ""

#. type: Plain text
#: raw/zstd/man1/zstd.1:21
msgid ""
"B<zstd> is a fast lossless compression algorithm and data compression tool, "
"with command line syntax similar to B<gzip>(1) and B<xz>(1). It is based on "
"the B<LZ77> family, with further FSE & huff0 entropy stages. B<zstd> offers "
"highly configurable compression speed, from fast modes at E<gt> 200 MB/s per "
"core, to strong modes with excellent compression ratios. It also features a "
"very fast decoder, with speeds E<gt> 500 MB/s per core, which remains "
"roughly stable at all compression settings."
msgstr ""

#. type: Plain text
#: raw/zstd/man1/zstd.1:24
msgid ""
"B<zstd> command line syntax is generally similar to gzip, but features the "
"following few differences:"
msgstr ""

